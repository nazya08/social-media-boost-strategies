# Data store (choose one)
# - airtable: uses Airtable tables (default)
# - supabase: uses Supabase/Postgres (no Airtable API limits)
DATA_STORE=airtable

# Airtable
AIRTABLE_API_KEY=         # Personal Access Token from airtable.com/account
AIRTABLE_BASE_ID=         # From the base URL: airtable.com/app.../
AIRTABLE_TABLE_NAME=Posts
AIRTABLE_DONORS_TABLE_NAME=Threads Donors
AIRTABLE_RUN_LOGS_TABLE_NAME=Run Logs

# Supabase (required when DATA_STORE=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# This repo's default schema uses prefix `social_media_strategy_`
SUPABASE_TABLE_PREFIX=social_media_strategy_
# Base table names (prefix is applied automatically by the app/script)
SUPABASE_DONORS_TABLE_NAME=threads_donors
SUPABASE_POSTS_TABLE_NAME=posts
SUPABASE_RUN_LOGS_TABLE_NAME=run_logs

# Threads API (for posting only — your account)
THREADS_ACCESS_TOKEN=           # Long-lived token (60 days)
THREADS_USER_ID=                # Your numeric Threads user ID
THREADS_DEVICE_ID=android-3jex3zty23s00000
THREADS_REPLY_RETRY_COUNT=3
THREADS_REPLY_RETRY_DELAY_MS=30000
THREADS_INTER_PART_DELAY_MS=30000

# Multi-account (optional)
# - Add `Account Key` field to Airtable tables: `Threads Donors` and `Posts`.
# - Default account key is `DEFAULT` (blank `Account Key` records are treated as DEFAULT for backward compatibility).
THREADS_DEFAULT_ACCOUNT_KEY=DEFAULT
# Additional accounts (comma-separated keys). Keys are uppercased and non [A-Z0-9_] chars become `_`.
THREADS_ADDITIONAL_ACCOUNTS=AI_BUILDERS_LAB,AI_SOLUTIONSHUB
# Per additional account:
THREADS_ACCESS_TOKEN_AI_BUILDERS_LAB=
THREADS_USER_ID_AI_BUILDERS_LAB=
THREADS_DEVICE_ID_AI_BUILDERS_LAB=android-9f3a8c1d2e4b6a7c
THREADS_ACCESS_TOKEN_AI_SOLUTIONSHUB=
THREADS_USER_ID_AI_SOLUTIONSHUB=
THREADS_DEVICE_ID_AI_SOLUTIONSHUB=android-1a2b3c4d5e6f7788
# Optional: run only specific accounts in this invocation (comma-separated keys).
# Used by `.github/workflows/cron.yml` to schedule different accounts at different cadences.
THREADS_RUN_ONLY_ACCOUNTS=DEFAULT

# Prompt threads are long; use faster delays to avoid serverless timeouts
PROMPT_THREAD_INTER_PART_DELAY_MS=5000
PROMPT_THREAD_REPLY_RETRY_DELAY_MS=20000

# Run Logs (persisted in Airtable Run Logs table, or in Supabase `run_logs` when DATA_STORE=supabase)
RUN_LOGS_AIRTABLE_ENABLED=true
# Recommended: keep only WARN/ERROR/CRITICAL in DB to slow down growth
RUN_LOGS_MIN_LEVEL=WARN
# Automatic trimming of oldest Run Logs
RUN_LOGS_CLEANUP_THRESHOLD_RECORDS=900
RUN_LOGS_CLEANUP_TRIM_TO_RECORDS=700

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Telegram alerts (no content posting, alerts only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=-1002984562783
TELEGRAM_MESSAGE_THREAD_ID=206
TELEGRAM_ALERTS_ENABLED=true

# Runtime behavior
AUTOPUBLISH_ENABLED=true
POST_MEDIA_ENABLED=false
PUBLISH_MAX_PER_RUN=1
DAILY_BATCH_ENABLED=false
DAILY_BATCH_HOUR=9
DAILY_BATCH_MINUTE=0
INGEST_MAX_ITEMS_PER_DONOR=1
# Optional: skip RSS items that contain media (image/video) at ingest time.
# You can also set per account key: INGEST_SKIP_MEDIA_AI_BUILDERS_LAB=true
INGEST_SKIP_MEDIA=false
# Optional: if an RSS provider returns HTTP 402 (Payment Required), automatically disable the donor (Status=Inactive)
# to avoid repeated errors. You can re-enable after fixing the feed/provider.
INGEST_AUTO_DISABLE_ON_402=false
GENERATE_MAX_RECORDS=20

# Target length for non-list threads (prompt/news). For tool_list/alternatives_list we force 2 parts (root+CTA).
PARTS_TARGET_MIN=8
PARTS_TARGET_MAX=10

SCHEDULE_MODE=interval
BATCH_SLOT_HOURS=12,15,18,21
INTERVAL_HOURS=2
WINDOW_START_HOUR=9
WINDOW_END_HOUR=21
TARGET_POSTS_PER_DAY_MIN=3
TARGET_POSTS_PER_DAY_MAX=5

# Threads text limit: 500 characters (including spaces and links)
THREAD_PART_MAX_CHARS=500
TIMEZONE=America/New_York

# CTA (stored per post in Airtable at ingest time)
CTA_URL=https://t.me/solutions_247ai
CTA_TEXT_EN=
CTA_TEXT_UA=Більше про AI та автоматизацію тут:

CTA_TEXT_UA=Більше про AI та автоматизацію тут:

# Leave CTA_TEXT_UA blank to use the default from code (Ukrainian).
CTA_TEXT_UA=

# Optional: override CTA URL per account key (e.g. CTA_URL_AI_BUILDERS_LAB=...)
CTA_URL_AI_BUILDERS_LAB=
CTA_URL_AI_SOLUTIONSHUB=

# Optional: override CTA text per account key
# (e.g. CTA_TEXT_EN_DEFAULT=..., CTA_TEXT_UA_AI_BUILDERS_LAB=...)
CTA_TEXT_EN_DEFAULT=
CTA_TEXT_UA_DEFAULT=
CTA_TEXT_EN_AI_BUILDERS_LAB=
CTA_TEXT_UA_AI_BUILDERS_LAB=
CTA_TEXT_EN_AI_SOLUTIONSHUB=
CTA_TEXT_UA_AI_SOLUTIONSHUB=

# Optional: force ingest language per account (EN/UA) regardless of donor.language
# Useful when using a shared donor pool for multiple accounts.
INGEST_LANGUAGE=
INGEST_LANGUAGE_DEFAULT=
INGEST_LANGUAGE_AI_BUILDERS_LAB=
INGEST_LANGUAGE_AI_SOLUTIONSHUB=

# Cron protection (recommended for production)
CRON_SECRET=
